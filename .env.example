# 数据库
# Docker 单镜像默认使用 SQLite 文件库，低内存运行。
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/chem-qa.sqlite

# MySQL（本地开发如需 docker-compose，可改 DATABASE_TYPE=mysql 并使用下方配置）
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3307
DATABASE_USER=chem_user
DATABASE_PASSWORD=chem_pass_dev_2026
DATABASE_NAME=chem_qa

# API
API_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ========== 平台大模型（必填，由你在服务端配置）==========
# 注意：Key 必须与 Base URL 来自同一平台，修改后必须重启 npm run dev
#
# 【DeepSeek 示例】在 https://platform.deepseek.com 申请 API Key
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=sk-4013ef27ffcc4994af1d49eb79270535
LLM_MODEL_NAME=deepseek-chat
#
# 【通义千问 OpenAI 兼容模式示例】
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-你的通义密钥
# LLM_MODEL_NAME=qwen-turbo

# 前端开发代理目标
VITE_API_URL=http://localhost:3001

# CORS / Cookie
CLIENT_URL=http://localhost:5173

# 数据初始化：always=每次启动重建知识点；missing=仅空库导入；never=不导入
INIT_CONTENT=missing

# ========== 邮件发送（注册验证码 / 找回密码，QQ 邮箱 SMTP）==========
# 开通方法：登录 QQ 邮箱 → 设置 → 账号 → 开启「IMAP/SMTP 服务」→ 生成 16 位「授权码」
# 注意：SMTP_PASS 填的是授权码（不是 QQ 登录密码）；SMTP_USER 填完整 QQ 邮箱地址
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-qq-number@qq.com
SMTP_PASS=your-16-char-authorization-code
MAIL_FROM=your-qq-number@qq.com
