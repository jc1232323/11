# MySQL（与 docker-compose.yml 默认一致）
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3307
DATABASE_USER=chem_user
DATABASE_PASSWORD=chem_pass_dev_2026
DATABASE_NAME=chem_qa

# API
API_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ========== 平台大模型（必填，由你在服务端配置）==========
# 注意：Key 必须与 Base URL 来自同一平台，修改后必须重启 npm run dev
#
# 【DeepSeek 示例】在 https://platform.deepseek.com 申请 API Key
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=sk-4013ef27ffcc4994af1d49eb79270535
LLM_MODEL_NAME=deepseek-chat
#
# 【通义千问 OpenAI 兼容模式示例】
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-你的通义密钥
# LLM_MODEL_NAME=qwen-turbo

# 前端开发代理目标
VITE_API_URL=http://localhost:3001

# CORS / Cookie
CLIENT_URL=http://localhost:5173

# SMTP 邮件服务配置（QQ 邮箱请填写授权码，不是 QQ 登录密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-qq-mail-authorization-code
MAIL_FROM="化学知识问答 <your-email@qq.com>"
