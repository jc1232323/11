{
  "name": "chem-qa",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "predev": "lsof -ti :3001,:5173,:5174,:5175,:5176,:5200 2>/dev/null | xargs kill -9 2>/dev/null || true",
    "stop": "lsof -ti :3001,:5173,:5174,:5175,:5176,:5200 2>/dev/null | xargs kill -9 2>/dev/null || true",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev -w @chem-qa/api\" \"npm run dev -w @chem-qa/web\"",
    "dev:all": "concurrently -k -n api,web,admin -c blue,green,magenta \"npm run dev -w @chem-qa/api\" \"npm run dev -w @chem-qa/web\" \"npm run dev -w @chem-qa/admin\"",
    "dev:api": "npm run dev -w @chem-qa/api",
    "dev:web": "npm run dev -w @chem-qa/web",
    "dev:admin": "npm run dev -w @chem-qa/admin",
    "build": "npm run build -w @chem-qa/api && npm run build -w @chem-qa/web && npm run build -w @chem-qa/admin",
    "lint:web": "eslint apps/web/src --ext .ts,.tsx",
    "mail:test": "ts-node --project scripts/tsconfig.json scripts/check-smtp.ts",
    "make-admin": "ts-node --project scripts/tsconfig.json scripts/make-admin.ts",
    "import-content": "npm run import-content -w @chem-qa/api",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "ts-node": "^10.9.2",
    "dotenv": "^16.4.7",
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript-eslint": "^8.34.1"
  }
}
